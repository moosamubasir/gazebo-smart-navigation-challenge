<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="bonus_grid_world">
    <plugin name="gazebo_ros_init" filename="libgazebo_ros_init.so"/>
    <plugin name="gazebo_ros_factory" filename="libgazebo_ros_factory.so"/>
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50.0</update_rate>
    </plugin>

    <gravity>0 0 -9.8</gravity>
    <scene>
      <ambient>0.55 0.55 0.55 1</ambient>
      <background>0.03 0.04 0.06 1</background>
      <shadows>false</shadows>
    </scene>

    <light name="sun" type="directional">
      <pose>0 0 8 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -1</direction>
    </light>

    <model name="floor">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5.2 5.2 0.04</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5.2 5.2 0.04</size></box></geometry>
          <material><ambient>0.18 0.18 0.18 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="start_green_cell">
      <static>true</static>
      <pose>-2 -2 0.026 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.94 0.94 0.012</size></box></geometry>
          <material><ambient>0.0 0.8 0.12 1</ambient><diffuse>0.0 0.8 0.12 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="end_red_cell">
      <static>true</static>
      <pose>2 2 0.027 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.94 0.94 0.012</size></box></geometry>
          <material><ambient>0.9 0.05 0.04 1</ambient><diffuse>0.9 0.05 0.04 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="north_wall"><static>true</static><pose>0 2.6 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>5.4 0.15 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>5.4 0.15 0.5</size></box></geometry><material><ambient>0.0 0.08 0.75 1</ambient><diffuse>0.0 0.08 0.75 1</diffuse></material></visual></link></model>
    <model name="south_wall"><static>true</static><pose>0 -2.6 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>5.4 0.15 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>5.4 0.15 0.5</size></box></geometry><material><ambient>0.0 0.08 0.75 1</ambient><diffuse>0.0 0.08 0.75 1</diffuse></material></visual></link></model>
    <model name="east_wall"><static>true</static><pose>2.6 0 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.15 5.4 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.15 5.4 0.5</size></box></geometry><material><ambient>0.0 0.08 0.75 1</ambient><diffuse>0.0 0.08 0.75 1</diffuse></material></visual></link></model>
    <model name="west_wall"><static>true</static><pose>-2.6 0 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.15 5.4 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.15 5.4 0.5</size></box></geometry><material><ambient>0.0 0.08 0.75 1</ambient><diffuse>0.0 0.08 0.75 1</diffuse></material></visual></link></model>

    <model name="grid_x_neg2"><static>true</static><pose>-1.5 0 0.035 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>0.025 5.0 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_x_neg1"><static>true</static><pose>-0.5 0 0.035 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>0.025 5.0 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_x_pos1"><static>true</static><pose>0.5 0 0.035 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>0.025 5.0 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_x_pos2"><static>true</static><pose>1.5 0 0.035 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>0.025 5.0 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_y_neg2"><static>true</static><pose>0 -1.5 0.036 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>5.0 0.025 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_y_neg1"><static>true</static><pose>0 -0.5 0.036 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>5.0 0.025 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_y_pos1"><static>true</static><pose>0 0.5 0.036 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>5.0 0.025 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>
    <model name="grid_y_pos2"><static>true</static><pose>0 1.5 0.036 0 0 0</pose><link name="link"><visual name="visual"><geometry><box><size>5.0 0.025 0.01</size></box></geometry><material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material></visual></link></model>

    <model name="obstacle_1"><static>true</static><pose>-2 0 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.72 0.72 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.72 0.72 0.5</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual></link></model>
    <model name="obstacle_2"><static>true</static><pose>-1 -1 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.72 0.72 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.72 0.72 0.5</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual></link></model>
    <model name="obstacle_3"><static>true</static><pose>0 1 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.72 0.72 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.72 0.72 0.5</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual></link></model>
    <model name="obstacle_4"><static>true</static><pose>1 1 0.25 0 0 0</pose><link name="link"><collision name="collision"><geometry><box><size>0.72 0.72 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.72 0.72 0.5</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual></link></model>
    <model name="obstacle_5"><static>false</static><pose>2 -1 0.25 0 0 0</pose><link name="link"><gravity>false</gravity><collision name="collision"><geometry><box><size>0.72 0.72 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.72 0.72 0.5</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual></link></model>

    <model name="bonus_1"><static>false</static><pose>0 -2 0.045 0 0 0</pose><link name="link"><gravity>false</gravity><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>0.035</length></cylinder></geometry><material><ambient>1 0.82 0.0 1</ambient><diffuse>1 0.82 0.0 1</diffuse></material></visual></link></model>
    <model name="bonus_2"><static>false</static><pose>-1 1 0.045 0 0 0</pose><link name="link"><gravity>false</gravity><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>0.035</length></cylinder></geometry><material><ambient>1 0.82 0.0 1</ambient><diffuse>1 0.82 0.0 1</diffuse></material></visual></link></model>
    <model name="bonus_3"><static>false</static><pose>1 0 0.045 0 0 0</pose><link name="link"><gravity>false</gravity><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>0.035</length></cylinder></geometry><material><ambient>1 0.82 0.0 1</ambient><diffuse>1 0.82 0.0 1</diffuse></material></visual></link></model>

    <model name="collector_bot">
      <pose>-2 -2 0.09 0 0 0</pose>
      <link name="base_link">
        <inertial><mass>1.0</mass><inertia><ixx>0.03</ixx><iyy>0.03</iyy><izz>0.03</izz></inertia></inertial>
        <collision name="base_collision"><geometry><box><size>0.34 0.25 0.16</size></box></geometry></collision>
        <visual name="base_visual"><geometry><box><size>0.34 0.25 0.16</size></box></geometry><material><ambient>1.0 0.35 0.0 1</ambient><diffuse>1.0 0.35 0.0 1</diffuse></material></visual>
      </link>
      <link name="left_wheel">
        <pose>0 0.17 -0.035 1.5707 0 0</pose>
        <inertial><mass>0.08</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.055</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.055</radius><length>0.04</length></cylinder></geometry><material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
      </link>
      <link name="right_wheel">
        <pose>0 -0.17 -0.035 1.5707 0 0</pose>
        <inertial><mass>0.08</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.055</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.055</radius><length>0.04</length></cylinder></geometry><material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
      </link>
      <link name="lidar_link">
        <pose>0 0 0.14 0 0 0</pose>
        <visual name="visual"><geometry><cylinder><radius>0.08</radius><length>0.05</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
        <sensor name="lidar" type="ray">
          <always_on>true</always_on>
          <visualize>true</visualize>
          <update_rate>10</update_rate>
          <ray>
            <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
            <range><min>0.08</min><max>6.0</max><resolution>0.01</resolution></range>
          </ray>
          <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
            <ros><remapping>~/out:=scan</remapping></ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>
          </plugin>
        </sensor>
      </link>
      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child>
        <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent><child>right_wheel</child>
        <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <joint name="lidar_joint" type="fixed">
        <parent>base_link</parent><child>lidar_link</child>
      </joint>
      <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros><remapping>cmd_vel:=cmd_vel</remapping><remapping>odom:=odom</remapping></ros>
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.34</wheel_separation>
        <wheel_diameter>0.11</wheel_diameter>
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>false</publish_wheel_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
      </plugin>
    </model>
  </world>
</sdf>
